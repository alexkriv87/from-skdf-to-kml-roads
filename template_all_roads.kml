<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://earth.google.com/kml/2.2">
  <Document>
    <!-- ОСНОВНАЯ ПАПКА-ОБЁРТКА -->
    <Folder>
      <name>{top_folder_name}</name>
      <open>1</open>
      <Style>
        <ListStyle>
          <listItemType>check</listItemType>
          <bgColor>00ffffff</bgColor>
        </ListStyle>
      </Style>

      <!-- ПАПКА "1. ДОРОГИ" -->
      <Folder>
        <name>1. Дороги</name>
        <open>1</open>
        <Style>
          <ListStyle>
            <listItemType>check</listItemType>
            <bgColor>00ffffff</bgColor>
          </ListStyle>
        </Style>

        <!-- 1. ФЕДЕРАЛЬНЫЕ -->
        <Folder>
          <name>1. Федеральные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {federal}
        </Folder>

        <!-- 2. РЕГИОНАЛЬНЫЕ -->
        <Folder>
          <name>2. Региональные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {regional}
        </Folder>

        <!-- 3. МЕСТНЫЕ -->
        <Folder>
          <name>3. Местные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {local}
        </Folder>

        <!-- 4. ЧАСТНЫЕ -->
        <Folder>
          <name>4. Частные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {private}
        </Folder>

        <!-- 5. ЛЕСНЫЕ -->
        <Folder>
          <name>5. Лесные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {forest}
        </Folder>

        <!-- 6. ВЕДОМСТВЕННЫЕ -->
        <Folder>
          <name>6. Ведомственные</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
          {departmental}
        </Folder>

      </Folder>  <!-- закрывает "1. Дороги" -->

      <!-- ПАПКА "2. КИЛОМЕТРОВЫЕ СТОЛБЫ" -->
      <Folder>
        <name>2. Километровые столбы</name>
        <open>1</open>
        <Style>
          <ListStyle>
            <listItemType>check</listItemType>
            <bgColor>00ffffff</bgColor>
          </ListStyle>
        </Style>
        {km_posts}
      </Folder>

      <!-- ПАПКА "4. ТОЧКИ ИНТЕРЕСА" (ЗАГОТОВКА) -->
      <Folder>
        <name>4. Точки интереса</name>
        <open>1</open>
        <Style>
          <ListStyle>
            <listItemType>check</listItemType>
            <bgColor>00ffffff</bgColor>
          </ListStyle>
        </Style>
        <Folder>
          <name>Точки интереса</name>
          <open>1</open>
          <Style>
            <ListStyle>
              <listItemType>check</listItemType>
              <bgColor>00ffffff</bgColor>
            </ListStyle>
          </Style>
        </Folder>
      </Folder>

    </Folder>  <!-- закрывает основную папку-обёртку -->
  </Document>
</kml>