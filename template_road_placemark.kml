<!-- ОДНА ДОРОГА (Placemark) -->
<Placemark>
  <name>{name}</name>                     <!-- плейсхолдер: название дороги -->
  <description>{description}</description> <!-- плейсхолдер: описание дороги -->
  <Style>
    <LineStyle>
      <color>{color}</color>              <!-- плейсхолдер: цвет линии -->
      <width>{width}</width>              <!-- плейсхолдер: толщина линии -->
    </LineStyle>
  </Style>
  <LineString>
    <extrude>1</extrude>
    <coordinates>{coordinates}</coordinates> <!-- плейсхолдер: координаты -->
  </LineString>
</Placemark>